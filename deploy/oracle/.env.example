# MineOpsWeb production environment (Oracle VM)
# Copy to .env on the Oracle host and keep private.

# Image tags (latest for auto-push from main; pin to sha for rollback)
WEB_IMAGE_TAG=latest
PB_IMAGE_TAG=latest

# PocketBase bootstrap credentials
PB_ADMIN_EMAIL=replace-me@example.com
PB_ADMIN_PASSWORD=replace-with-strong-password
