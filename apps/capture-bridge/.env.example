# =============================================================================
# MineOps Capture Bridge — Environment Configuration
# =============================================================================
# Copy this file to .env locally; never commit .env.
#
# This CLI runs on ubuntumac (or your dev machine) and uploads APK extraction
# payloads to the MineOps PocketBase capture-ingest endpoint.
# =============================================================================

# PocketBase capture ingest endpoint
# Local dev: http://localhost:8090/api/capture/ingest
# Oracle staging: https://mineops-pb.shepswork.com/api/capture/ingest
MINEOPS_CAPTURE_URL=http://localhost:8090/api/capture/ingest

# Bearer token for capture client auth.
# Create a record in the PocketBase capture_clients collection via Admin UI,
# then set the token here.
MINEOPS_CAPTURE_TOKEN=fill-in-from-pb-admin
