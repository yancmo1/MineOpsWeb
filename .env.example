# =============================================================================
# MineOpsWeb – Environment Configuration
# =============================================================================
# Copy this file to .env locally; never commit .env.
#
# PocketBase endpoints: 
#   http://localhost:8090               → local Docker PB (docker compose)
#   https://mineops-pb.shepswork.com    → Oracle staging (default for dev)
#
# To switch, change VITE_POCKETBASE_URL below.
# =============================================================================

APP_ENV=development
APP_NAME=MineOpsWeb
APP_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080

# PocketBase
VITE_POCKETBASE_URL=https://mineops-pb.shepswork.com
PB_ADMIN_EMAIL=pocketbase@shepswork.com 
PB_ADMIN_PASSWORD=fill-in-a-local-password

# Kolibri Capsule credentials (local development only)
VITE_KOLIBRI_ID=
VITE_KOLIBRI_AUTH_TOKEN=
VITE_KOLIBRI_SAVE_GAME_KEY=0

# Capture bridge — ubuntumac APK extraction pipeline
# URL of the PocketBase capture-ingest endpoint.
# Local dev: http://localhost:8090/api/capture/ingest
# Oracle staging: https://mineops-pb.shepswork.com/api/capture/ingest
MINEOPS_CAPTURE_URL=http://localhost:8090/api/capture/ingest
# Bearer token for capture client auth — create a capture client record in
# PocketBase Admin UI (capture_clients collection) and use its token here.
MINEOPS_CAPTURE_TOKEN=fill-in-later
