# Local MineOpsWeb development configuration.
# Copy this file to .env locally; never commit .env.
APP_ENV=development
APP_NAME=MineOpsWeb
APP_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080

# Local PocketBase
VITE_POCKETBASE_URL=http://localhost:8090
PB_ADMIN_EMAIL=yancmo@gmail.com
PB_ADMIN_PASSWORD=fill-in-a-local-password

# Kolibri Capsule credentials (local development only)
VITE_KOLIBRI_ID=
VITE_KOLIBRI_AUTH_TOKEN=
VITE_KOLIBRI_SAVE_GAME_KEY=0

# Reserved for the later Ubuntu capture bridge; leave unchanged for now.
CAPTURE_INGESTION_TOKEN=fill-in-later
