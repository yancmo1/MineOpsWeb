{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mineops.io/schemas/catalog_diff.schema.json",
  "title": "MineOps Catalog Diff",
  "description": "Domain-level diff between two catalog versions. Reports additions, removals, changes, and unresolved objects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "diffSchemaVersion",
    "catalogVersion",
    "previousCatalogVersion",
    "generatedAt",
    "summary",
    "changes"
  ],
  "properties": {
    "diffSchemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1,
      "description": "The new (candidate) catalog version."
    },
    "previousCatalogVersion": {
      "type": ["string", "null"],
      "description": "The baseline catalog version, or null for the first version."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "$ref": "#/$defs/diffSummary"
    },
    "changes": {
      "$ref": "#/$defs/diffChanges"
    }
  },
  "$defs": {
    "diffSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "managersAdded", "managersRemoved", "managersChanged",
        "identifiersChanged", "spritesChanged", "abilitiesChanged",
        "unresolvedObjects", "warnings"
      ],
      "properties": {
        "managersAdded": { "type": "integer", "minimum": 0 },
        "managersRemoved": { "type": "integer", "minimum": 0 },
        "managersChanged": { "type": "integer", "minimum": 0 },
        "identifiersChanged": { "type": "integer", "minimum": 0 },
        "spritesChanged": { "type": "integer", "minimum": 0 },
        "abilitiesChanged": { "type": "integer", "minimum": 0 },
        "unresolvedObjects": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 }
      }
    },
    "diffChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "removed", "changed", "unresolved"],
      "properties": {
        "added": {
          "type": "array",
          "items": { "$ref": "#/$defs/addRemoveEntry" }
        },
        "removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/addRemoveEntry" }
        },
        "changed": {
          "type": "array",
          "items": { "$ref": "#/$defs/changedEntry" }
        },
        "unresolved": {
          "type": "array",
          "items": { "$ref": "#/$defs/unresolvedDiffEntry" }
        }
      }
    },
    "addRemoveEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId", "entityType"],
      "properties": {
        "canonicalId": { "type": "string", "minLength": 1 },
        "entityType": {
          "type": "string",
          "enum": ["manager", "mine", "equipment", "research", "collectible", "artifact"]
        },
        "name": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"],
          "description": "error for unexpected removals; warning for large additions."
        }
      }
    },
    "changedEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId", "field", "before", "after", "severity"],
      "properties": {
        "canonicalId": { "type": "string", "minLength": 1 },
        "field": {
          "type": "string",
          "minLength": 1,
          "description": "Dot-separated field path that changed."
        },
        "before": {
          "description": "Previous value (any type)."
        },
        "after": {
          "description": "New value (any type)."
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    },
    "unresolvedDiffEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceObjectId", "reason", "severity"],
      "properties": {
        "sourceObjectId": { "type": "string", "minLength": 1 },
        "reason": {
          "type": "string",
          "enum": [
            "missing_identity",
            "ambiguous_identity",
            "unsupported_type",
            "missing_required_field",
            "possible_duplicate"
          ]
        },
        "candidateCanonicalIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    }
  }
}
