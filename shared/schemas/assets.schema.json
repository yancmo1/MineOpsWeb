{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mineops.io/schemas/assets.schema.json",
  "title": "MineOps Catalog Assets",
  "description": "Asset reference index for sprite sheets, textures, audio, and other game assets. One artifact in the versioned JSON package.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogVersion",
    "releaseId",
    "generatedAt",
    "assets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this assets schema."
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Deterministic bundle version string matching the manifest."
    },
    "releaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Source release identity from the capture envelope."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when this artifact was generated."
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/assetRecord" },
      "description": "Asset reference index."
    }
  },
  "$defs": {
    "assetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId", "type", "path"],
      "properties": {
        "canonicalId": {
          "type": "string",
          "minLength": 1,
          "description": "Stable asset identifier (referenced by entity spriteRefs)."
        },
        "type": {
          "type": "string",
          "enum": ["sprite_sheet", "texture", "audio", "font", "shader", "prefab", "other"],
          "description": "Asset type classification."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path within the extraction bundle."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of the raw asset file."
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes."
        },
        "mimeType": {
          "type": ["string", "null"],
          "description": "MIME type of the asset."
        },
        "width": { "type": ["integer", "null"], "minimum": 0 },
        "height": { "type": ["integer", "null"], "minimum": 0 },
        "sourceIdentifiers": {
          "type": "object",
          "additionalProperties": { "type": ["string", "null"] }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
