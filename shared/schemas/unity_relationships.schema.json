{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MineOps Unity Relationships",
  "type": "object",
  "additionalProperties": false,
  "required": ["releaseId", "generatedAt", "relationships"],
  "properties": {
    "releaseId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fromId", "toId", "relationshipType", "source", "status"],
        "properties": {
          "fromId": { "type": "string", "minLength": 1 },
          "toId": { "type": "string", "minLength": 1 },
          "relationshipType": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
