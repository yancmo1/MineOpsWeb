{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mineops.io/schemas/catalog_validation.schema.json",
  "title": "MineOps Catalog Validation Report",
  "description": "Deterministic validation checks run against a normalized catalog. Records schema validity, identity conflicts, reference integrity, hash consistency, and suspicious changes. Does not activate anything.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validationSchemaVersion",
    "catalogVersion",
    "validatedAt",
    "status",
    "checks",
    "blockingIssues",
    "warnings",
    "counts"
  ],
  "properties": {
    "validationSchemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1
    },
    "validatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "review_required", "failed"],
      "description": "Overall validation status. 'review_required' means warnings exist; 'failed' means blocking issues."
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationCheck" }
    },
    "blockingIssues": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationIssue" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/validationIssue" }
    },
    "counts": {
      "$ref": "#/$defs/validationCounts"
    }
  },
  "$defs": {
    "validationCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "passed", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Unique check identifier (e.g. SCHEMA_VALID, DUPLICATE_CANONICAL_ID)."
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "passed": {
          "type": "boolean",
          "description": "Whether the check succeeded."
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable result message."
        },
        "path": {
          "type": ["string", "null"],
          "description": "JSON path to the problematic entity, or null for global checks."
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional structured details about the check result."
        }
      }
    },
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": ["string", "null"] },
        "canonicalId": { "type": ["string", "null"] },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "validationCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["errors", "warnings", "unresolved"],
      "properties": {
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "unresolved": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
