{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MineOps APK Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageName",
    "versionName",
    "versionCode",
    "capturedAt",
    "adbSerial",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "versionName": {
      "type": "string",
      "minLength": 1
    },
    "versionCode": {
      "type": "integer",
      "minimum": 1
    },
    "capturedAt": {
      "type": "string",
      "minLength": 1
    },
    "adbSerial": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "devicePath",
          "sizeBytes",
          "sha256"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "devicePath": {
            "type": "string",
            "minLength": 1
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
