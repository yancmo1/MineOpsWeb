{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mineops.io/schemas/changelog.schema.json",
  "title": "MineOps Catalog Changelog",
  "description": "Structured changelog recording domain-level differences between two catalog versions. One artifact in the versioned JSON package.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogVersion",
    "previousCatalogVersion",
    "generatedAt",
    "summary",
    "changes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this changelog schema."
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1,
      "description": "The new (candidate) catalog version."
    },
    "previousCatalogVersion": {
      "type": ["string", "null"],
      "description": "The baseline catalog version, or null for the first version."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when this changelog was generated."
    },
    "summary": {
      "$ref": "#/$defs/changelogSummary"
    },
    "changes": {
      "$ref": "#/$defs/changelogChanges"
    }
  },
  "$defs": {
    "changelogSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "managersAdded", "managersRemoved", "managersChanged",
        "identifiersChanged", "spritesChanged", "abilitiesChanged",
        "unresolvedObjects", "warnings"
      ],
      "properties": {
        "managersAdded": { "type": "integer", "minimum": 0 },
        "managersRemoved": { "type": "integer", "minimum": 0 },
        "managersChanged": { "type": "integer", "minimum": 0 },
        "identifiersChanged": { "type": "integer", "minimum": 0 },
        "spritesChanged": { "type": "integer", "minimum": 0 },
        "abilitiesChanged": { "type": "integer", "minimum": 0 },
        "unresolvedObjects": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 }
      }
    },
    "changelogChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "removed", "changed", "unresolved"],
      "properties": {
        "added": {
          "type": "array",
          "items": { "$ref": "#/$defs/addRemoveEntry" }
        },
        "removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/addRemoveEntry" }
        },
        "changed": {
          "type": "array",
          "items": { "$ref": "#/$defs/changedEntry" }
        },
        "unresolved": {
          "type": "array",
          "items": { "$ref": "#/$defs/unresolvedEntry" }
        }
      }
    },
    "addRemoveEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId", "entityType"],
      "properties": {
        "canonicalId": { "type": "string", "minLength": 1 },
        "entityType": {
          "type": "string",
          "enum": ["manager", "mine", "equipment", "research", "collectible", "artifact"]
        },
        "name": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    },
    "changedEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId", "entityType", "fields"],
      "properties": {
        "canonicalId": { "type": "string", "minLength": 1 },
        "entityType": {
          "type": "string",
          "enum": ["manager", "mine", "equipment", "research", "collectible", "artifact"]
        },
        "name": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/fieldChange" }
        }
      }
    },
    "fieldChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "before", "after"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "before": {},
        "after": {},
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    },
    "unresolvedEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalId"],
      "properties": {
        "canonicalId": { "type": "string", "minLength": 1 },
        "entityType": {
          "type": "string",
          "enum": ["manager", "mine", "equipment", "research", "collectible", "artifact"]
        },
        "reason": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    }
  }
}
